{
    "oversized_in_gui": true,
    "model": {
        "type": "range_dispatch",
        "property": "custom_model_data",
        "fallback": {
            "type": "model",
            "model": "minecraft:item/paper"
        },
        "entries": [
            {
                "threshold": 1000,
                "model": {
                    "type": "model",
                    "model": "custom:ui/icon/icon_empty"
                }
            },
            {
                "threshold": 200,
                "model": {
                    "type": "model",
                    "model": "custom:ui/buttons/button_quit"
                }
            },
            {
                "threshold": 210,
                "model": {
                    "type": "model",
                    "model": "custom:ui/buttons/button_arrow_up"
                }
            },
            {
                "threshold": 211,
                "model": {
                    "type": "model",
                    "model": "custom:ui/buttons/button_arrow_down"
                }
            },
            {
                "threshold": 212,
                "model": {
                    "type": "model",
                    "model": "custom:ui/buttons/button_arrow_left"
                }
            },
            {
                "threshold": 213,
                "model": {
                    "type": "model",
                    "model": "custom:ui/buttons/button_arrow_right"
                }
            },
            {
                "threshold": 214,
                "model": {
                    "type": "model",
                    "model": "custom:ui/buttons/button_list"
                }
            },
            {
                "threshold": 218,
                "model": {
                    "type": "model",
                    "model": "custom:ui/buttons/button_add"
                }
            },
            {
                "threshold": 220,
                "model": {
                    "type": "model",
                    "model": "custom:ui/buttons/button_check"
                }
            }
        ]
    }
}